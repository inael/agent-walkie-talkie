# ========================================
# Agent Walkie-Talkie — Environment Config
# ========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Redis (message hub) ---
REDIS_URL=redis://localhost:6379

# --- Discord Bot ---
# Create bot at: https://discord.com/developers/applications
# Full guide: docs/DISCORD_BOT_SETUP.md
DISCORD_TOKEN=your-bot-token-here
DISCORD_CHANNEL_ID=your-channel-id-here

# --- Web UI ---
WEB_PORT=3210

# --- Worker (orchestrator daemon) ---
# Path to Claude Code CLI executable
# Linux/Mac: claude
# Windows: C:/Users/YOUR_USER/AppData/Roaming/npm/claude.cmd
CLAUDE_CLI_PATH=claude

# Max simultaneous conversations the worker handles
MAX_CONCURRENT_CONVERSATIONS=3

# Default max rounds per conversation (agents can override via wt_start)
DEFAULT_MAX_ROUNDS=10

# Timeout per round in milliseconds (300000 = 5 minutes)
ROUND_TIMEOUT_MS=300000
